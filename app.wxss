/**app.wxss**/
/* 全局样式变量 */
page {
  --primary-color: #ff6bb5;
  --primary-light: #ff8ae2;
  --primary-dark: #e55aa0;
  --secondary-color: #6c5ce7;
  --accent-color: #00cec9;
  --success-color: #00b894;
  --warning-color: #fdcb6e;
  --error-color: #e17055;
  --text-primary: #2d3436;
  --text-secondary: #636e72;
  --text-light: #b2bec3;
  --bg-primary: #ffffff;
  --bg-secondary: #f8f9fa;
  --bg-gradient: linear-gradient(135deg, #ff75d6 0%, #f8b2db 100%);
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-medium: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  --shadow-heavy: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
  --border-radius: 20rpx;
  --border-radius-large: 30rpx;
  --border-radius-small: 10rpx;
  --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 全局容器样式 */
.container {
  min-height: 100vh;
  background: var(--bg-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 通用按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  border-radius: var(--border-radius);
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: var(--transition);
  border: none;
  outline: none;
  cursor: pointer;
}

.btn-primary {
  background: var(--bg-gradient);
  color: white;
  box-shadow: var(--shadow-medium);
}

.btn-primary:active {
  transform: translateY(2rpx);
  box-shadow: var(--shadow-light);
}

.btn-secondary {
  background: var(--bg-secondary);
  color: var(--text-primary);
  border: 2rpx solid var(--text-light);
}

.btn-secondary:active {
  background: var(--text-light);
  color: white;
}

/* 通用卡片样式 */
.card {
  background: var(--bg-primary);
  border-radius: var(--border-radius);
  box-shadow: var(--shadow-light);
  padding: 30rpx;
  margin: 20rpx 0;
  transition: var(--transition);
}

.card:hover {
  transform: translateY(-4rpx);
  box-shadow: var(--shadow-medium);
}

/* 通用输入框样式 */
.input-field {
  width: 100%;
  padding: 24rpx 30rpx;
  border: 2rpx solid var(--text-light);
  border-radius: var(--border-radius);
  font-size: 28rpx;
  background: var(--bg-primary);
  transition: var(--transition);
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 6rpx rgba(255, 107, 181, 0.1);
}

/* 通用标题样式 */
.title {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  text-align: center;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
}

/* 通用分割线 */
.divider {
  width: 100%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--text-light), transparent);
  margin: 30rpx 0;
}

/* 加载动画 */
.loading {
  display: inline-block;
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--text-light);
  border-radius: 50%;
  border-top-color: var(--primary-color);
  animation: spin 1s ease-in-out infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 响应式布局 */
@media (max-width: 750rpx) {
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 24rpx;
  }
  
  .card {
    padding: 20rpx;
    margin: 15rpx 0;
  }
} 
