.container {
  padding: 40rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  margin-top: 80rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-bottom: 30rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #666;
  display: block;
}

.forgot-password-form {
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.input-item {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 30rpx;
  position: relative;
}

.icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.5;
}

.input-item input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.code-btn {
  position: absolute;
  right: 0;
  font-size: 26rpx;
  color: #1296db;
  padding: 10rpx 0;
}

.reset-btn {
  width: 100%;
  height: 90rpx;
  background-color: #FF85A1;
  color: #fff;
  border-radius: 45rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: background-color 0.3s;
}

.reset-btn:active {
  background-color: #FF6B8B;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 10rpx;
  filter: brightness(0) invert(1);
}

.login-link {
  text-align: center;
  font-size: 26rpx;
  color: #1296db;
  margin-top: 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.link-icon {
  width: 30rpx;
  height: 30rpx;
  margin-right: 8rpx;
}