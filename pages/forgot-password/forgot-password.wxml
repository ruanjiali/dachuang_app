<view class="container">
  <!-- 顶部logo和标题 -->
  <view class="header">
    <image class="logo" src="/images/logo.png"></image>
    <text class="title">AI穿搭魔法师</text>
    <text class="subtitle">忘记密码</text>
  </view>

  <!-- 忘记密码表单 -->
  <view class="forgot-password-form">
    <view class="input-item">
      <image class="icon" src="/images/用户.png" mode="aspectFit"></image>
      <input type="number" placeholder="请输入手机号" bindinput="onPhoneInput" value="{{phone}}" />
    </view>
    <view class="input-item">
      <image class="icon" src="/images/验证码.png" mode="aspectFit"></image>
      <input type="number" placeholder="请输入验证码" bindinput="onCodeInput" value="{{code}}" />
      <text class="code-btn" bindtap="getVerificationCode">{{countdown > 0 ? countdown + 's后重新获取' : '获取验证码'}}</text>
    </view>
    <view class="input-item">
      <image class="icon" src="/images/密码.png" mode="aspectFit"></image>
      <input type="password" placeholder="请输入新密码" bindinput="onNewPasswordInput" value="{{newPassword}}" password="true" />
    </view>
    <view class="input-item">
      <image class="icon" src="/images/密码.png" mode="aspectFit"></image>
      <input type="password" placeholder="请确认密码" bindinput="onConfirmPasswordInput" value="{{confirmPassword}}" password="true" />
    </view>
    <button class="reset-btn" bindtap="resetPassword" style="width: 274rpx; display: flex; box-sizing: border-box; left: 0rpx; top: 0rpx">
      <image class="btn-icon" src="/images/确认.png" mode="aspectFit"></image>
      <text style="position: relative; left: -25rpx; top: 3rpx">重置密码</text>
    </button>
    <view class="login-link" bindtap="goBackToLogin">
      <image class="link-icon" src="/images/返回.png" mode="aspectFit"></image>
      <text style="position: relative; left: -19rpx; top: 19rpx">返回登录</text>
    </view>
  </view>
</view>