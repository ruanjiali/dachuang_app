  transform: translateX(-50%);
  width: 16rpx;
  height: 3rpx;
  background: linear-gradient(90deg, #ff6bb5, #6c5ce7);
  border-radius: 2rpx;
  animation: indicatorPulse 2s ease-in-out infinite;
}

@keyframes indicatorPulse {
  0%, 100% { opacity: 1; transform: translateX(-50%) scaleX(1); }
  50% { opacity: 0.7; transform: translateX(-50%) scaleX(1.2); }
}

.nav-item text {
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 550;
  display: block;
  transition: color 0.3s ease;
}

.nav-item.active text {
  color: var(--primary-color);
  font-weight: 600;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .function-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 12rpx;
  }
  
  .features-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 15rpx;
  }
  
  .welcome-section {
    padding: 40rpx 30rpx;
  }
  
  .main-title {
    font-size: 32rpx;
  }
  
  .greeting-text {
    font-size: 24rpx;
  }
  
  .header-bg {
    height: 180rpx;
  }
  
  .function-card {
    padding: 18rpx 12rpx;
  }
  
  .card-name {
    font-size: 18rpx;
  }
  
  .card-desc {
    font-size: 14rpx;
  }
}

/* 特色卡片区域 */
.featured-card-section {
  text-align: center;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: center;
}

