page {
  --primary-color: #ff6bb5;
  --secondary-color: #6c5ce7;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-color: #f8f8f8;
  --card-bg: #ffffff;
}

.page {
  min-height: 100vh;
  padding: 0 0 140rpx;
  background-color: var(--bg-color);
}

/* 头部区域 */
.hero {
  background-color: var(--card-bg);
  padding: 40rpx 30rpx;
  border-bottom: 1rpx solid #e8e8e8;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-color);
  text-align: center;
}

.hero-subtitle {
  display: block;
  color: var(--text-secondary);
  font-size: 24rpx;
  text-align: center;
  margin-top: 12rpx;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 40rpx;
  margin: 20rpx;
  background: var(--card-bg);
  border-radius: 16rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.step-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8e8e8;
  color: var(--text-light);
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step.active .step-dot {
  background: var(--primary-color);
  color: #fff;
}

.step.completed .step-dot {
  background: #52c41a;
  color: #fff;
}

.step-text {
  font-size: 20rpx;
  color: var(--text-light);
}

.step.active .step-text,
.step.completed .step-text {
  color: var(--text-primary);
  font-weight: 500;
}

.step-line {
  width: 50rpx;
  height: 2rpx;
  background: #e8e8e8;
  margin: 0 12rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #52c41a;
}

/* 选择状态标签 */
.selection-status {
  padding: 0 20rpx 10rpx;
}

.status-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.status-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.style-tag {
  background: #fff0f5;
  color: var(--primary-color);
}

.scene-tag {
  background: #f0f5ff;
  color: var(--secondary-color);
}

/* 面板卡片 */
.panel {
  margin: 20rpx;
  background: var(--card-bg);
  padding: 24rpx;
  border-radius: 16rpx;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  color: var(--text-primary);
  font-size: 32rpx;
  font-weight: bold;
}

.section-desc {
  display: block;
  color: var(--text-secondary);
  font-size: 22rpx;
  margin-top: 6rpx;
}

/* 风格卡片网格 */
.style-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.style-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid transparent;
}

.style-card.active {
  border-color: var(--primary-color);
  background: #fff5fa;
}

.style-image {
  width: 100%;
  height: 130rpx;
  object-fit: cover;
}

.style-info {
  padding: 14rpx;
}

.style-name {
  display: block;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
  text-align: center;
}

.style-desc {
  display: block;
  color: var(--text-secondary);
  font-size: 20rpx;
  margin-top: 6rpx;
  text-align: center;
}

/* 场景选择 */
.scene-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.scene-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  border-radius: 40rpx;
  background: #f0f0f0;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.scene-chip.active {
  background: var(--primary-color);
  color: #fff;
}

.scene-icon {
  font-size: 26rpx;
}

/* 生成按钮 */
.action-box {
  padding: 30rpx 20rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: var(--primary-color);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.7;
}

.btn-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255,255,255,0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 结果卡片 */
.result-card {
  margin: 20rpx;
  background: var(--card-bg);
  padding: 28rpx;
  border-radius: 16rpx;
}

.result-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-title-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.result-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.result-separator {
  font-size: 28rpx;
  color: var(--primary-color);
}

.result-subtitle {
  display: block;
  text-align: center;
  color: var(--text-light);
  font-size: 22rpx;
  margin-top: 10rpx;
}

/* AI建议内容 */
.ai-advice-section {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.advice-header {
  margin-bottom: 16rpx;
}

.advice-header-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.advice-content {
  background: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  border-left: 4rpx solid var(--primary-color);
}

.advice-text {
  display: block;
  color: var(--text-primary);
  font-size: 26rpx;
  line-height: 1.9;
  white-space: pre-wrap;
}

/* 推荐单品 */
.result-block {
  margin-top: 24rpx;
}

.block-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.block-icon {
  font-size: 28rpx;
}

.block-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.item-row {
  display: flex;
  align-items: center;
  background: #fafafa;
  border-radius: 12rpx;
  padding: 16rpx;
}

.item-img {
  width: 90rpx;
  height: 90rpx;
  border-radius: 10rpx;
  margin-right: 16rpx;
}

.item-main {
  flex: 1;
}

.item-name {
  display: block;
  color: var(--text-primary);
  font-size: 26rpx;
  font-weight: 600;
}

.item-meta {
  display: block;
  color: var(--text-secondary);
  font-size: 22rpx;
  margin-top: 4rpx;
}

.item-price {
  display: block;
  color: var(--primary-color);
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 6rpx;
}

.fav-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.fav-btn::after {
  border: none;
}

.fav-btn image {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.4;
}

.fav-btn.active {
  background: var(--primary-color);
  border-color: var(--primary-color);
}

.fav-btn.active image {
  filter: brightness(0) invert(1);
  opacity: 1;
}

/* 小贴士 */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tip-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 10rpx;
}

.tip-badge {
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #fff;
  font-size: 20rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tip-text {
  flex: 1;
  color: var(--text-primary);
  font-size: 24rpx;
  line-height: 1.6;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--card-bg);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn image {
  width: 32rpx;
  height: 32rpx;
}

.action-btn.secondary {
  background: #f0f0f0;
  color: var(--text-primary);
}

.action-btn.primary {
  background: var(--primary-color);
  color: #fff;
}
