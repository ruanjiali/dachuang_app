.page {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #eef3ff 0%, #f8f9ff 100%);
}

.hero {
  margin: 8rpx 8rpx 20rpx;
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1d2a57;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5e6b8f;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 12rpx 36rpx rgba(28, 47, 110, 0.08);
  margin-bottom: 18rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #25315f;
}

.section-action {
  font-size: 28rpx;
  color: #476bff;
}

.section-tip {
  font-size: 22rpx;
  color: #7b86a8;
}

.choose-area {
  width: 100%;
  height: 460rpx;
  border-radius: 20rpx;
  border: 2rpx dashed #ccdafd;
  background: #f7f9ff;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.source-image {
  width: 100%;
  height: 100%;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  margin-top: 10rpx;
  color: #6e7aa3;
  font-size: 24rpx;
}

.primary-btn {
  width: 100%;
  height: 86rpx;
  line-height: 86rpx;
  margin-top: 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(90deg, #4b6dff 0%, #6f8bff 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.ghost-btn {
  width: 100%;
  height: 82rpx;
  line-height: 82rpx;
  margin-top: 14rpx;
  border-radius: 16rpx;
  background: #f0f4ff;
  color: #3d61eb;
  font-size: 26rpx;
}

.status-card {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.status-text {
  color: #2f67ff;
  font-size: 26rpx;
}

.status-text.error {
  color: #de2a49;
}

.error-text {
  display: block;
  margin-top: 10rpx;
  color: #de2a49;
  font-size: 23rpx;
  word-break: break-all;
  line-height: 1.6;
}

.log-card {
  background: #fbfcff;
}

.log-title {
  display: block;
  color: #3f4a73;
  font-size: 25rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.log-item {
  color: #66729c;
  font-size: 22rpx;
  line-height: 1.7;
  word-break: break-all;
}

.result-card {
  padding-bottom: 20rpx;
}

.result-image {
  width: 100%;
  height: 460rpx;
  border-radius: 18rpx;
  background: #f4f7ff;
  border: 2rpx solid #e2e9ff;
}

.save-btn {
  margin-top: 18rpx;
}

.footer-space {
  height: 24rpx;
}
