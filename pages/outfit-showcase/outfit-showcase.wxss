.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 头部样式 */
.header {
  height: 200rpx;
  background: linear-gradient(135deg, #f8b0d4 0%, #ff88cc 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: white;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 内容区域 */
.content-section {
  padding: 20rpx;
}

/* 空状态样式 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  background-color: #fff;
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.empty-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
  opacity: 0.7;
}

.empty-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 40rpx;
}

.upload-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #ff6bb5 0%, #ff88cc 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
  font-weight: 500;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 181, 0.3);
}

.upload-btn:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 10rpx rgba(255, 107, 181, 0.2);
}

/* 搭配列表样式 */
.outfit-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

/* 搭配卡片样式 */
.outfit-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.outfit-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.main-image {
  width: 100%;
  height: 400rpx;
}

/* 搭配信息 */
.outfit-info {
  padding: 25rpx;
}

.outfit-description {
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 15rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.outfit-time {
  font-size: 24rpx;
  color: #999;
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
  margin-bottom: 10rpx;
}

.outfit-count {
  font-size: 26rpx;
  color: #666;
}

.upload-btn-sm {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 28rpx;
  background: linear-gradient(135deg, #ff6bb5 0%, #ff88cc 100%);
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 181, 0.3);
}

.upload-btn-sm:active {
  transform: scale(0.95);
}

/* 卡片图片包裹层（用于定位删除按钮） */
.card-image-wrap {
  position: relative;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.delete-btn:active {
  background: rgba(255, 68, 68, 0.8);
  transform: scale(0.9);
}

.delete-icon {
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1;
}

/* 搭配 meta 信息行（时间 + 点赞） */
.outfit-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10rpx;
}

.like-area {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.like-icon {
  font-size: 28rpx;
  color: #ff6bb5;
}

.like-count {
  font-size: 26rpx;
  color: #999;
}
