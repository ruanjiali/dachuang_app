/* pages/add-clothes/add-clothes.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  padding: 40rpx 0;
  background-color: #fff;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.upload-area {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.image-container {
  display: flex;
  flex-wrap: wrap;
}

.image-item {
  width: 280rpx;
  height: 280rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.upload-btn {
  width: 280rpx;
  height: 280rpx;
  border: 2rpx dashed #ccc;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  border-radius: 8rpx;
}

.upload-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.upload-btn text {
  font-size: 24rpx;
  color: #999;
}

.custom-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.custom-dialog {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 20rpx 20rpx 0 0;
  z-index: 1000;
  padding-bottom: 30rpx;
}

.dialog-content {
  padding: 30rpx;
}

.dialog-option {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.option-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.dialog-option text {
  font-size: 28rpx;
  color: #333;
}

.dialog-cancel {
  text-align: center;
  padding: 30rpx 0;
  margin-top: 20rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
}

.info-section {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input-group input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #666;
}

.input-group textarea {
  width: 100%;
  border: 1rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  min-height: 160rpx;
}

.submit-btn {
  background-color: #f78dd3;
  color: #fff;
  border-radius: 8rpx;
  margin-top: 30rpx;
  margin-bottom: 50rpx;
}

.submit-btn:active {
  background-color: #ec51b9;
}