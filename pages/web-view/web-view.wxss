/* web-view.wxss */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.back-btn {
  font-size: 28rpx;
  padding: 0 20rpx;
  height: 60rpx;
  line-height: 60rpx;
}

.image-section {
  margin-bottom: 30rpx;
}

.instruction {
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #f5f5f5;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.image-container {
  width: 100%;
  height: 400rpx;
  border: 1px solid #eee;
  border-radius: 10rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.preview-image {
  width: 100%;
  height: 350rpx;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #999;
}

.select-btn {
  margin-bottom: 30rpx;
}

.web-view-section {
  width: 100%;
  height: 700rpx; /* 增加高度 */
  margin: 0 auto 30rpx; /* 水平居中 */
  border: 1px solid #eee;
  border-radius: 10rpx;
  overflow: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.web-view-section web-view {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.result-section {
  margin-top: 30rpx;
}

.save-btn {
  margin-top: 20rpx;
}
