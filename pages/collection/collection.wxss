page {
  --primary-color: #ff6bb5;
  --secondary-color: #6c5ce7;
  --text-primary: #2d3436;
  --text-secondary: #636e72;
  --bg-gradient: linear-gradient(135deg, #ff75d6 0%, #f8b2db 100%);
  --shadow-light: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  --shadow-heavy: 0 15rpx 40rpx rgba(0, 0, 0, 0.15);
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #ffffff 100%);
  padding-bottom: 120rpx;
}

.header {
  padding: 80rpx 40rpx 54rpx;
  background: var(--bg-gradient);
  border-radius: 0 0 36rpx 36rpx;
  box-shadow: var(--shadow-heavy);
}

.header-content {
  text-align: center;
}

.header .title {
  font-size: 52rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 16rpx;
}

.header .subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.stats-section {
  padding: 22rpx 40rpx;
}

.stats-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 24rpx;
  box-shadow: var(--shadow-light);
  display: flex;
  align-items: center;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-number {
  display: block;
  font-size: 42rpx;
  color: var(--primary-color);
  font-weight: 700;
}

.stats-label {
  display: block;
  margin-top: 4rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
}

.stats-divider {
  width: 2rpx;
  height: 60rpx;
  background: #eceef5;
}

.collection-content {
  padding: 0 40rpx;
}

.tab-container {
  display: flex;
  background: #fff;
  border-radius: 18rpx;
  padding: 8rpx;
  box-shadow: var(--shadow-light);
}

.tab-item {
  flex: 1;
  text-align: center;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 14rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

.tab-item.active {
  background: var(--primary-color);
  color: #fff;
}

.search-row {
  margin-top: 16rpx;
}

.search-input-wrap {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: var(--shadow-light);
}

.search-input {
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 25rpx;
}

.sort-row {
  margin-top: 14rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sort-chip {
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  box-shadow: var(--shadow-light);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.sort-chip.active {
  background: var(--primary-color);
  color: #fff;
}

.tab-content {
  margin-top: 16rpx;
}

.empty-state {
  background: #fff;
  border-radius: 22rpx;
  padding: 74rpx 32rpx;
  text-align: center;
  box-shadow: var(--shadow-light);
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  display: block;
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 600;
}

.empty-subtitle {
  display: block;
  color: var(--text-secondary);
  font-size: 24rpx;
  margin: 10rpx 0 26rpx;
}

.go-home-btn {
  width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--bg-gradient);
  color: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
}

.clothes-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.clothes-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-light);
}

.clothes-image {
  width: 100%;
  height: 220rpx;
}

.price-badge {
  margin: -36rpx 0 0 14rpx;
  width: fit-content;
  background: rgba(0, 0, 0, 0.62);
  color: #fff;
  font-size: 20rpx;
  border-radius: 999rpx;
  padding: 4rpx 12rpx;
  position: relative;
  z-index: 1;
}

.clothes-info {
  padding: 14rpx 16rpx 12rpx;
}

.clothes-name {
  display: block;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 600;
  white-space: nowrap;
  text-overflow: ellipsis;
  overflow: hidden;
}

.clothes-category {
  display: block;
  margin-top: 4rpx;
  color: var(--text-secondary);
  font-size: 22rpx;
}

.tag-row {
  margin-top: 10rpx;
  display: flex;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  background: #f2f5fb;
  color: #5b678f;
}

.remove-btn {
  margin: 0 16rpx 14rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 12rpx;
  background: #fff1f4;
  color: #e45575;
  font-size: 24rpx;
}

.advice-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.advice-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: var(--shadow-light);
}

.advice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.advice-meta {
  color: var(--primary-color);
  font-size: 25rpx;
  font-weight: 600;
}

.advice-date {
  color: #9aa3be;
  font-size: 21rpx;
}

.advice-content {
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.65;
}

.advice-remove {
  margin: 14rpx 0 0;
}

.bottom-actions {
  position: fixed;
  left: 0;
  bottom: 0;
  width: 100%;
  background: #fff;
  box-shadow: 0 -8rpx 30rpx rgba(0, 0, 0, 0.08);
  padding: 16rpx 40rpx;
  display: flex;
  gap: 16rpx;
}

.action-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 27rpx;
}

.action-btn image {
  width: 30rpx;
  height: 30rpx;
}

.action-btn.secondary {
  background: #f2f5fb;
  color: var(--text-primary);
}

.action-btn.primary {
  background: linear-gradient(135deg, #ff7b9f 0%, #ff5c7d 100%);
  color: #fff;
}
