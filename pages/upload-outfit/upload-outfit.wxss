.container {
  padding: 20rpx;
  box-sizing: border-box;
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f7fa 0%, #e9ecef 100%);
}

/* 头部样式 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #ff6bb5 0%, #ff88cc 100%);
  border-radius: 20rpx;
  margin: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 181, 0.2);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
}

/* 上传区域样式 */
.upload-area {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease;
}

.upload-area:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

/* 图片容器样式 */
.image-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 10rpx 0;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.image-item:hover {
  transform: scale(1.05);
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 15rpx;
}

/* 删除按钮样式 */
.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.delete-btn:active {
  background-color: #ff6b6b;
  transform: scale(0.9);
}

.delete-btn image {
  width: 30rpx;
  height: 30rpx;
}

/* 上传按钮样式 */
.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 3rpx dashed #ff6bb5;
  border-radius: 15rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #fff5f8;
  transition: all 0.3s ease;
}

.upload-btn:active {
  background-color: #ffe6ec;
  transform: scale(0.98);
}

.upload-icon {
  width: 60rpx;
  height: 60rpx;
  opacity: 0.8;
}

.upload-btn text {
  font-size: 28rpx;
  color: #ff6bb5;
  margin-top: 15rpx;
  font-weight: 500;
}

.tips {
  font-size: 24rpx;
  color: #999;
  margin-top: 20rpx;
  display: block;
  text-align: center;
}

/* 描述区域样式 */
.description-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.3s ease;
}

.description-section:active {
  transform: translateY(2rpx);
}

textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  color: #333;
  padding: 25rpx;
  box-sizing: border-box;
  border: 2rpx solid #f0f0f0;
  border-radius: 15rpx;
  line-height: 1.6;
  background-color: #fafafa;
  transition: all 0.3s ease;
}

textarea:focus {
  border-color: #ff6bb5;
  background-color: #fff;
  outline: none;
  box-shadow: 0 0 0 4rpx rgba(255, 107, 181, 0.1);
}

textarea::placeholder {
  color: #ccc;
}

/* 提交按钮样式 */
.submit-btn {
  width: 90%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff6bb5 0%, #ff88cc 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 34rpx;
  margin: 40rpx auto;
  border: none;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 181, 0.3);
  transition: all 0.3s ease;
  display: block;
}

.submit-btn:active {
  transform: translateY(4rpx);
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 181, 0.2);
  background: linear-gradient(135deg, #ff57a8 0%, #ff77bf 100%);
}

/* 自定义上传弹窗样式 */
.custom-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding-bottom: 80rpx;
  animation: fadeIn 0.3s;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.custom-dialog {
  position: fixed;
  bottom: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 85%;
  background-color: #fff;
  border-radius: 30rpx;
  z-index: 1000;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.3s;
}

@keyframes slideUp {
  from { transform: translateX(-50%) translateY(100rpx); opacity: 0; }
  to { transform: translateX(-50%) translateY(0); opacity: 1; }
}

.dialog-content {
  padding: 30rpx 0;
}

.dialog-option {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 35rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.dialog-option:active {
  background-color: #f9f9f9;
}

.option-icon {
  width: 50rpx;
  height: 50rpx;
  margin-right: 20rpx;
}

.dialog-option text {
  font-size: 34rpx;
  color: #333;
}

.dialog-cancel {
  padding: 35rpx 0;
  text-align: center;
  font-size: 34rpx;
  color: hsl(323, 84%, 66%);
  font-weight: bold;
}

.dialog-cancel:active {
  background-color: #f9f9f9;
}